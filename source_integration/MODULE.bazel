elixir_packages = use_extension(
    "@rules_elixir_mix//bzlmod:packages.bzl",
    "elixir_packages",
)
elixir_packages.mix_lock(
    name = "mix_deps",
    lockfile = "//:mix.lock",
    precompiled_native_files = {
        "lazy_html": "//:lazy_html_nif",
    },
)
use_repo(elixir_packages, "hex_pm", "mix_deps")

register_toolchains(
    "@elixir_config//catalog_source_arm64:otp_toolchain",
    "@elixir_config//catalog_source_arm64:test_toolchain",
    "@elixir_config//catalog_source_arm64:toolchain",
    "@elixir_config//catalog_source_glibc_arm64:otp_toolchain",
    "@elixir_config//catalog_source_glibc_arm64:test_toolchain",
    "@elixir_config//catalog_source_glibc_arm64:toolchain",
    "@elixir_config//catalog_source_glibc_x86_64:otp_toolchain",
