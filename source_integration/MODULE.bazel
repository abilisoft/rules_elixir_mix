        "erts-17.0.3/bin/erlexec",
        "releases/29/OTP_VERSION",
        "releases/29/start_clean.boot",
    ],
    sha256 = "c44ba721fd224a0ca98ae736b2932f84f6c4d9aaf3179aeed5de555ca815d0b4",
    urls = ["https://github.com/gleam-community/erlang-linux-builds/releases/download/OTP-29.0.3/erlang-29.0.3-x64.tar.gz"],
