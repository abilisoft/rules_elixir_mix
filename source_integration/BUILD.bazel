load(
    "@rules_elixir_mix//:defs.bzl",
    "elixir_fips_runtime_test",
    "elixir_release_test",
    "mix_escript",
    "mix_library",
    "mix_release",
    "mix_test",
    "otp_prebuilt_release",
)
load("@rules_elixir_mix//:integration/generated_asset.bzl", "escript_write")
load(":rules_fips_sdk.bzl", "rules_fips_crypto_sdk")

package(default_visibility = ["//visibility:public"])

otp_prebuilt_release(
    name = "bootstrap_otp",
    srcs = ["@bootstrap_otp_runtime//:runtime"],
    boot_file = "@bootstrap_otp_runtime//:releases/29/start_clean.boot",
    erlexec = "@bootstrap_otp_runtime//:erts-17.0.3/bin/erlexec",
    exec_compatible_with = [
        "@platforms//cpu:x86_64",
        "@platforms//os:linux",
    ],
    fully_static = True,
    libc = "glibc",
    version = "29.0.3",
    version_marker = "@bootstrap_otp_runtime//:releases/29/OTP_VERSION",
)

otp_prebuilt_release(
    name = "bootstrap_otp_arm64",
    srcs = ["@bootstrap_otp_runtime_arm64//:runtime"],
    boot_file = "@bootstrap_otp_runtime_arm64//:releases/29/start_clean.boot",
    erlexec = "@bootstrap_otp_runtime_arm64//:erts-17.0.3/bin/erlexec",
    exec_compatible_with = [
        "@platforms//cpu:arm64",
        "@platforms//os:linux",
    ],
    fully_static = True,
    libc = "glibc",
    version = "29.0.3",
    version_marker = "@bootstrap_otp_runtime_arm64//:releases/29/OTP_VERSION",
)

rules_fips_crypto_sdk(name = "openssl_fips_crypto_sdk")

platform(
    name = "source_execution_x86_64",
    constraint_values = [
        "@rules_fips//fips/platforms:glibc_2_35",
        "@rules_fips//fips/platforms:openssl_fips_glibc_amd64",
        "@elixir_config//:runtime_catalog_source_glibc_x86_64",
        "@platforms//cpu:x86_64",
        "@platforms//os:linux",
    ],
    exec_properties = {
        "Arch": "amd64",
        "EstimatedCPU": "4",
        "EstimatedMemory": "8GB",
        "OSFamily": "linux",
    },
)

platform(
    name = "source_execution_arm64",
    constraint_values = [
        "@rules_fips//fips/platforms:glibc_2_35",
