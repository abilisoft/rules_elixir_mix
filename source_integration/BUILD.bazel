filegroup(
    name = "lazy_html_nif",
    srcs = select({
        ":target_glibc_arm64": ["@lazy_html_nif_glibc_arm64//:liblazy_html.so"],
        ":target_glibc_x86_64": ["@lazy_html_nif_glibc_x86_64//:liblazy_html.so"],
        ":target_musl_arm64": ["@lazy_html_nif_musl_arm64//:liblazy_html.so"],
        ":target_musl_x86_64": ["@lazy_html_nif_musl_x86_64//:liblazy_html.so"],
    }),
)

elixir_fips_runtime_test(
    name = "fips_runtime",
    tags = ["manual"],
)

mix_library(
    name = "test_app",
    srcs = glob(["lib/**/*.ex"]),
    app_name = "source_integration_app",
    config = glob(["config/*.exs"]),
    lockfile = "mix.lock",
    mix_config = "mix.exs",
    mix_env = "test",
    runtime_deps = [
        "@mix_deps//:bandit",
        "@mix_deps//:jason",
        "@mix_deps//:lazy_html",
        "@mix_deps//:phoenix",
        "@mix_deps//:phoenix_html",
        "@mix_deps//:phoenix_live_view",
    ],
)

mix_test(
    name = "test",
    srcs = glob(["test/**/*.exs"]),
    lib = ":test_app",
)

mix_library(
    name = "app",
    srcs = glob(["lib/**/*.ex"]),
    app_name = "source_integration_app",
    config = glob(["config/*.exs"]),
    lockfile = "mix.lock",
    mix_config = "mix.exs",
    mix_env = "prod",
    runtime_deps = [
        "@mix_deps//:bandit",
        "@mix_deps//:jason",
        "@mix_deps//:phoenix",
        "@mix_deps//:phoenix_html",
        "@mix_deps//:phoenix_live_view",
    ],
)

mix_escript(
    name = "source_escript",
    lib = ":app",
    output_name = "source-integration-escript",
)

escript_write(
    name = "source_escript_codegen",
    tool = ":source_escript",
)

mix_release(
    name = "release",
    application = ":app",
    fips = "required",
)

elixir_release_test(
    name = "release_test",
    release = ":release",
    required_paths = [
        ".rules_elixir_mix/crypto_activation.config",
        ".rules_elixir_mix/crypto_sdk/bin/crypto-activate",
        ".rules_elixir_mix/crypto_sdk/lib/ossl-modules/fips.so",
        "bin/source_integration_app.rules_elixir_mix.crypto.json",
    ],
)
