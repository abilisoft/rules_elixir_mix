filegroup(
    name = "lazy_html_nif",
    srcs = select({
        "@platforms//cpu:arm64": ["@lazy_html_nif_arm64_linux_gnu//file"],
        "@platforms//cpu:x86_64": ["@lazy_html_nif_x86_64_linux_gnu//file"],
    }),
    visibility = ["//visibility:public"],
)

erlang_app(
    name = "direct_erlang_app",
    srcs = [
        "erlang/direct_fixture.erl",
        "erlang/direct_fixture_SUITE.erl",
        "@rules_elixir_mix//private:artifact_normalizer.erl",
        "@rules_elixir_mix//private:runtime_archive_driver.erl",
        "@rules_elixir_mix//test:src/artifact_normalizer_tests.erl",
        "@rules_elixir_mix//test:src/runtime_archive_driver_tests.erl",
    ],
