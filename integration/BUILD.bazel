        "@mix_deps//:phoenix_live_view",
        "@mix_deps//:postgrex",
    ],
)

elixir_protocols(
    name = "protocols",
    apps = [":release_lib"],
)

mix_release(
    name = "release",
    application = ":release_lib",
    mix_env = "test",
    protocols = ":protocols",
)

elixir_release_test(
    name = "release_test",
    consolidated_protocols = ["Elixir.Integration.Renderable"],
    release = ":release",
    required_file_contents = {
        "lib/integration-0.1.0/priv/static/generated.txt": "generated by a declared Bazel action\n",
    },
    required_paths = [
        "lib/integration-0.1.0/priv/static/cache_manifest.json",
        "lib/integration-0.1.0/priv/static/generated.txt",
    ],
)
